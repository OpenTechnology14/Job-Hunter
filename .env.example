# Default profile when --profile is not specified
ACTIVE_PROFILE=alex

# Google credentials path (only change if you moved the file)
# GOOGLE_CREDS_PATH=credentials/google_service_account.json

# ── Optional API Keys (all free unless noted) ──

# USAJobs (free — sign up at https://developer.usajobs.gov/)
# USAJOBS_API_KEY=your_api_key_here
# USAJOBS_EMAIL=your_email@example.com

# Adzuna (free — sign up at https://developer.adzuna.com/)
# ADZUNA_APP_ID=your_app_id
# ADZUNA_APP_KEY=your_app_key

# SerpAPI for Google Jobs (PAID ~$100/mo — https://serpapi.com/)
# SERPAPI_KEY=your_key
